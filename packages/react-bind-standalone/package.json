{
	"name": "@bind-ts/react-bind-standalone",
	"version": "0.0.1",
	"description": "Standalone React bind implementations with multiple state management options",
	"author": "",
	"license": "MIT",
	"type": "module",
	"exports": {
		"./tanstack-store": {
			"import": {
				"types": "./dist/esm/tanstack-store/index.d.ts",
				"default": "./dist/esm/tanstack-store/index.js"
			}
		},
		"./zustand": {
			"import": {
				"types": "./dist/esm/zustand/index.d.ts",
				"default": "./dist/esm/zustand/index.js"
			}
		},
		"./context": {
			"import": {
				"types": "./dist/esm/context/index.d.ts",
				"default": "./dist/esm/context/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"src",
		"!**/__tests__"
	],
	"scripts": {
		"build": "vite build && tsc --emitDeclarationOnly --outDir dist/esm",
		"test": "vitest run",
		"test:watch": "vitest",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@tanstack/react-store": "^0.7.0",
		"@tanstack/store": "^0.7.0",
		"zustand": "^5.0.0"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.0.0",
		"@types/react": "^19.0.0",
		"jsdom": "^26.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "^5.9.2",
		"vite": "^6.3.5",
		"vitest": "^3.2.4"
	}
}
